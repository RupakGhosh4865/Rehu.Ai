# ══════════════════════════════════════════════════════════════════════════════
#  Savant.ai — PRODUCTION environment template (NO REAL VALUES)
#  Copy to your host's secret store (Railway/Render/Fly) — never commit real keys.
#
#  When ENVIRONMENT=production the app REFUSES TO BOOT unless every value below
#  marked [REQUIRED-PROD] is set to a strong, non-default value. Generate secrets:
#      python -c "import secrets; print(secrets.token_urlsafe(48))"
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment switch ────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Secrets [REQUIRED-PROD] — must be strong (>= 24 chars) and NOT the defaults ─
SECRET_KEY=                      # python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=                      # python -c "import secrets;print(secrets.token_urlsafe(48))"

# ── Admin panel [REQUIRED-PROD] — strong password (>= 12 chars) ────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                  # strong, unique

# ── CORS [REQUIRED-PROD] — explicit origins, NEVER ["*"] in production ──────────
CORS_ORIGINS=["https://app.yourdomain.com","https://yourdomain.com"]

# ── TLS [REQUIRED-PROD] — must be true in production (emits HSTS) ──────────────
FORCE_HTTPS=true

# ── Database [REQUIRED-PROD] — managed Postgres, NOT sqlite ────────────────────
# For the pgvector knowledge dense-arm, use a Postgres with the `vector` extension
# (e.g. the pgvector/pgvector image, or RDS/Cloud SQL with pgvector enabled). The
# app runs CREATE EXTENSION IF NOT EXISTS vector at startup; if unavailable it
# transparently falls back to the JSON-blob knowledge backend (slower, O(n) search).
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/savant

# ── Stripe billing [REQUIRED-PROD for paid plans] ──────────────────────────────
STRIPE_API_KEY=                  # sk_live_...
STRIPE_WEBHOOK_SECRET=           # whsec_...  [REQUIRED-PROD] webhook fails closed without it
# Price ids for the PUBLIC plans we sell (match your Stripe products):
STRIPE_PRICE_GROWTH=             # price_...
STRIPE_PRICE_SCALE=              # price_...
STRIPE_PRICE_ENTERPRISE=         # price_...
# Legacy aliases — only set if you still have old subscriptions on these:
# STRIPE_PRICE_PILOT=
# STRIPE_PRICE_PROFESSIONAL=
# STRIPE_PRICE_BUSINESS=

# ── AI services ────────────────────────────────────────────────────────────────
LIVEAVATAR_API_KEY=
LIVEAVATAR_USE_SANDBOX=false     # false in production = real avatar + capacity
OPENAI_API_KEY=                  # sk-...
OPENAI_MODEL=gpt-4o-mini
RAG_USE_SEMANTIC=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Voice-only fallback (optional)
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ── Rate limiting (optionally Redis-backed across workers) ─────────────────────
RATE_LIMIT_ENABLED=true
# REDIS_URL=redis://:PASSWORD@HOST:6379/0   # set to share limits across workers

# ── Observability ──────────────────────────────────────────────────────────────
SENTRY_DSN=
AUDIT_LOG_ENABLED=true

# ── App URLs ───────────────────────────────────────────────────────────────────
APP_BASE_URL=https://app.yourdomain.com
# APP_ROOT_DOMAIN=yourdomain.com   # enables tenant subdomains
CHROMA_PERSIST_DIR=./data/chromadb
