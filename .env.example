# ══════════════════════════════════════════════════════════════════════════════
#  SuperHuman AI Persona Platform — Environment Variables
#  Copy this file to .env and fill in your API keys
#  NEVER commit .env to git — it's in .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED: API Keys ────────────────────────────────────────────────────────

# OpenAI — get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ElevenLabs — get from: https://elevenlabs.io/app/profile/api-key
ELEVENLABS_API_KEY=...

# HeyGen — get from: https://app.heygen.com/settings/api
HEYGEN_API_KEY=...

# Daily.co — get from: https://dashboard.daily.co/developers
DAILY_API_KEY=...

# Deepgram — get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=...

# ── Avatar & Voice Configuration ──────────────────────────────────────────────

# HeyGen streaming avatar ID — must support Interactive/Streaming Avatar
# List via GET /api/avatar/list when the server is running
HEYGEN_AVATAR_ID=Angela-inblackskirt-20220820

# Optional HeyGen voice for the streaming session (leave empty for avatar default)
# Do NOT use an ElevenLabs voice ID here — TTS uses ELEVENLABS_VOICE_ID separately
HEYGEN_VOICE_ID=

# ElevenLabs voice ID — get from: https://elevenlabs.io/app/voice-library
# Default: Rachel (21m00Tcm4TlvDq8ikWAM)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Optional Configuration ────────────────────────────────────────────────────

# OpenAI model (gpt-4o-mini is cheapest, gpt-4o is best quality)
OPENAI_MODEL=gpt-4o-mini

# ElevenLabs model (eleven_turbo_v2_5 = lowest latency)
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# App settings
DEBUG=false
SECRET_KEY=change-this-to-a-random-32-char-string

# CORS — set to your website domain in production
# CORS_ORIGINS=["https://yoursite.com", "https://www.yoursite.com"]
CORS_ORIGINS=["*"]
