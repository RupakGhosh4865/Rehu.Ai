# ══════════════════════════════════════════════════════════════════════════════
#  Savant.ai — Environment Variables
#  Copy to backend/.env or project root .env — NEVER commit real keys to git
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED (production calls) ───────────────────────────────────────────────

# LiveAvatar — https://app.liveavatar.com/settings/api
LIVEAVATAR_API_KEY=
LIVEAVATAR_USE_SANDBOX=true
# LIVEAVATAR_AVATAR_ID=
# LIVEAVATAR_VOICE_ID=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Hybrid knowledge retrieval (semantic + keyword). With a valid OPENAI_API_KEY
# the avatar answers paraphrased questions far more accurately. Set
# RAG_USE_SEMANTIC=false to force keyword-only (BM25) and skip embedding costs.
RAG_USE_SEMANTIC=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── OPTIONAL (voice-only fallback when LiveAvatar unavailable) ────────────────

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
DEEPGRAM_API_KEY=

# ── Smartsheet CRM (append leads as rows) ───────────────────────────────────
# Create an API token at: https://app.smartsheet.com/account#personalSettings
# Sheet ID is the number in your sheet URL: /sheets/{SHEET_ID}
SMARTSHEET_ACCESS_TOKEN=
SMARTSHEET_SHEET_ID=

# ── ADMIN (protect /admin and write APIs — leave empty to disable in dev) ─────

ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── APP ───────────────────────────────────────────────────────────────────────

DEBUG=false
SECRET_KEY=change-this-to-a-random-32-char-string
CORS_ORIGINS=["*"]

# ── Enterprise security ───────────────────────────────────────────────────────
# Set ENVIRONMENT=production to ENFORCE hardening: the app refuses to start with a
# weak SECRET_KEY/JWT_SECRET, wildcard CORS, or empty ADMIN_PASSWORD.
ENVIRONMENT=development
FORCE_HTTPS=false            # set true behind TLS to emit HSTS
RATE_LIMIT_ENABLED=true
AUDIT_LOG_ENABLED=true
# For production also set: a strong JWT_SECRET, explicit CORS_ORIGINS=["https://yourdomain"],
# and a real ADMIN_PASSWORD. Generate secrets with: python -c "import secrets;print(secrets.token_urlsafe(48))"

# Database (tenant-isolated storage). Empty = SQLite at ./data/savant.db (dev).
# Production: a managed Postgres URL, e.g.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/savant
DATABASE_URL=

# Knowledge + persona persistence (mount ./data as a volume in production)
CHROMA_PERSIST_DIR=./data/chromadb

# Error monitoring (optional)
SENTRY_DSN=

# ── Stripe billing (optional in dev) ──────────────────────────────────────────
# Price ids map to the plans we sell. See .env.production.example for the full set.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=

# ── Rate limiting (Redis optional; in-memory fallback in dev) ──────────────────
# REDIS_URL=redis://localhost:6379/0   # set to share rate-limit state across workers
