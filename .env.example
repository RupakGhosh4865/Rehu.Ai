# ══════════════════════════════════════════════════════════════════════════════
#  Rehu.ai — Environment Variables
#  Copy to backend/.env or project root .env — NEVER commit real keys to git
# ══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED (production calls) ───────────────────────────────────────────────

# LiveAvatar — https://app.liveavatar.com/settings/api
LIVEAVATAR_API_KEY=
LIVEAVATAR_USE_SANDBOX=true
# LIVEAVATAR_AVATAR_ID=
# LIVEAVATAR_VOICE_ID=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── OPTIONAL (voice-only fallback when LiveAvatar unavailable) ────────────────

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
DEEPGRAM_API_KEY=

# ── ADMIN (protect /admin and write APIs — leave empty to disable in dev) ─────

ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── APP ───────────────────────────────────────────────────────────────────────

DEBUG=false
SECRET_KEY=change-this-to-a-random-32-char-string
CORS_ORIGINS=["*"]

# Knowledge + persona persistence (mount ./data as a volume in production)
CHROMA_PERSIST_DIR=./data/chromadb
